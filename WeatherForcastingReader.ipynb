import numpy as np

def calculate_heat_index(temp_c, rh):
    """Calculates the apparent temperature (Heat Index) in Celsius."""
    # Convert Celsius to Fahrenheit for standard NOAA formula
    T = (temp_c * 9/5) + 32
    
    # Coefficients for the NOAA Heat Index regression equation
    c1, c2, c3 = -42.379, 2.04901523, 10.14333127
    c4, c5, c6 = -0.22475541, -0.00683783, -0.05481717
    c7, c8, c9 = 0.00122874, 0.00085282, -0.00000199
    
    hi_f = (c1 + (c2 * T) + (c3 * rh) + (c4 * T * rh) + (c5 * T**2) + 
            (c6 * rh**2) + (c7 * T**2 * rh) + (c8 * T * rh**2) + (c9 * T**2 * rh**2))
    
    # Convert back to Celsius
    return (hi_f - 32) * 5/9

def determine_weather_state(temp, rh, pressure_trend):
    """
    Classifies the weather state based on atmospheric inputs.
    pressure_trend: 'falling_rapidly', 'falling', 'steady', 'rising'
    """
    # Calculate apparent temperature impact
    heat_index = calculate_heat_index(temp, rh) if temp >= 27 else temp
    
    # Rule-based decision matrix for forecasting states
    if pressure_trend == "falling_rapidly":
        if temp < 3:
            return "Blizzard / Heavy Snow Warning"
        return "Severe Storm / Heavy Rain Approaching"
        
    elif pressure_trend == "falling":
        if rh > 80:
            return "Unsettled, Likely Rain"
        return "Increasing Cloudiness"
        
    elif pressure_trend == "rising":
        if temp < 0:
            return "Clear, Cold Frost Condition"
        return "Clearing Skies and Improving Weather"
        
    else:  # Steady pressure
        if temp >= 35 or heat_index >= 41:
            return "Dangerously Hot / Extreme Heat State"
        elif rh > 90:
            return "Dense Fog / High Humidity State"
        elif 40 <= rh <= 70 and 18 <= temp <= 26:
            return "Fair / Ideal Pleasant State"
        return "Stable / Partly Cloudy State"

# =====================================================================
# SIMULATION & TESTING OVER MULTIPLE WEATHER STATIONS
# =====================================================================
# Mock data matrix: [Temperature (°C), Relative Humidity (%), Pressure Trend]
weather_stations = {
    "Station Alpha (Coastal)": [24.5, 95.0, "falling"],
    "Station Bravo (Desert)":  [42.0, 15.0, "steady"],
    "Station Charlie (Plains)": [22.0, 85.0, "falling_rapidly"],
    "Station Delta (Alpine)":   [-2.0, 40.0, "rising"],
    "Station Echo (Valley)":    [23.0, 55.0, "steady"]
}

print("--- REGIONAL WEATHER STATE FORECAST REPORT --- \n")
for station, data in weather_stations.items():
    temperature = data[0]
    humidity = data[1]
    trend = data[2]
    
    state = determine_weather_state(temperature, humidity, trend)
    
    print(f"[{station}]")
    print(f" > Metrics: {temperature}°C, {humidity}% RH, Pressure Trend: {trend.upper()}")
    print(f" > Declared State: {state}\n")
